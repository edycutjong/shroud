# Shroud Environment Variables

# Stellar Network Configuration
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Soroban Smart Contract IDs
NEXT_PUBLIC_SHROUD_POOL_ID=CD...
NEXT_PUBLIC_ASP_REGISTRY_ID=CA...
NEXT_PUBLIC_GROTH16_VERIFIER_ID=CC...
# v3 cross-pool atomic-swap verifier (verify_proof)
NEXT_PUBLIC_CROSSPOOL_VERIFIER_ID=CD...XPL
# v3 multi-ASP federation registry (K-of-N threshold attestation)
NEXT_PUBLIC_ASP_FEDERATION_ID=CA...FED
